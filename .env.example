# All values are OPTIONAL — the app ships with working defaults that point at the
# live iClose database (the same Supabase project the web /experience uses).
# Override any of them for a different environment.

# Deployed iClose backend (only used by the commission-free "list your property" form → /api/listing)
EXPO_PUBLIC_API_BASE_URL=https://iclose.ae
# Supabase — the live listings database (iclose-academy-db). Defaults are baked in.
EXPO_PUBLIC_SUPABASE_URL=https://nnkicmfsdbfpucfcnutn.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Listing enquiry contact channels (WhatsApp / call) shown on the property detail
EXPO_PUBLIC_WHATSAPP_NUMBER=971501234567
EXPO_PUBLIC_CONTACT_PHONE=+971501234567
# Android Google Maps key (iOS uses Apple Maps by default)
GOOGLE_MAPS_API_KEY=YOUR-ANDROID-MAPS-KEY
