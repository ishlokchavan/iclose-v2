# Point the app at your deployed iClose backend (the /api/glass/* routes live here)
EXPO_PUBLIC_API_BASE_URL=https://iclose.ae
# Supabase (same project as the web app)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Android Google Maps key (iOS uses Apple Maps by default)
GOOGLE_MAPS_API_KEY=YOUR-ANDROID-MAPS-KEY
